---
import BaseLayout from "../layouts/BaseLayout.astro";

const experience = [
  {
    period: "2024 - настоящее время",
    role: "Senior / Lead Unreal Engine C++ Developer (VR / Multiplayer)",
    details:
      "Отвечаю за бизнес-критичные gameplay и сетевые подсистемы: стрельба, гранаты, урон, взаимодействия, серверная логика, UI/HUD, spectator UI. Участвовал в росте команды от 3 до 20+ разработчиков и в выпуске линейки из 7 игровых продуктов на едином VR-core."
  },
  {
    period: "2023 - 2024",
    role: "UE Developer / Feature Owner",
    details:
      "Реализовывал и стабилизировал core-механики в production-среде: сетевые взаимодействия, оптимизация производительности, backend-интеграции (JSON/REST), инструменты для ускорения интеграции контента и поддержки релизного цикла."
  },
  {
    period: "2020 - 2023",
    role: "Frontend / Backend Freelancer",
    details:
      "Разрабатывал коммерческие сайты и веб-фичи на стороне фриланса: преимущественно frontend, а также backend-интеграции и Python-скрипты под прикладные задачи."
  }
];
---

<BaseLayout
  title="Опыт работы | UE Programmer Portfolio"
  description="Роли, ответственность и продуктовый вклад Антона Бордуноса."
>
  <section class="hero">
    <h1>Опыт работы</h1>
    <p>Роли, ответственность и вклад в продукт на ключевых этапах карьеры.</p>
  </section>

  <section class="cards">
    {experience.map((item) => (
      <article class="card">
        <p>
          <strong>{item.period}</strong>
        </p>
        <h2>{item.role}</h2>
        <p>{item.details}</p>
      </article>
    ))}
  </section>
</BaseLayout>
