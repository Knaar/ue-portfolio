---
import BaseLayout from "../layouts/BaseLayout.astro";

const experience = [
  {
    key: 1,
    period: "Apr 2023 - Present",
    role: "PORTAL TECH - Lead UE C++ Programmer",
    details:
      "Led multiplayer VR shooter development for LBE Arena on UE4/UE5. Designed and maintained network architecture (C++/Blueprints), integrated Advanced Sessions and custom solutions, stabilized Oculus/Pico pipelines, improved FPS/latency/load, and drove feature delivery from design docs to release builds."
  },
  {
    key: 2,
    period: "Apr 2022 - May 2023",
    role: "OpenVus - Unreal Engine Developer",
    details:
      "Built interactive architectural VR projects on UE4/UE5, implemented gameplay/interaction/lighting pipelines (Blueprints/C++), optimized scenes for stable VR runtime, and handled technical support for demo sessions."
  },
  {
    key: 3,
    period: "Jun 2021 - Apr 2022",
    role: "Prostranstvo VR - UE Tech Artist / Unreal Developer",
    details:
      "Delivered interactive VR architectural content on UE4/UE5, built logic and visual scenarios, optimized assets and level performance, and supported equipment setup for client-facing presentations."
  },
  {
    key: 4,
    period: "Jan 2018 - Mar 2021",
    role: "Freelance - Frontend / Backend Web Developer",
    details:
      "Developed websites/landing pages (Tilda/WordPress and other CMS), customized frontend (HTML/CSS/JS), handled backend integrations and API flows, automated tasks with Python/PHP, and configured hosting/deployment basics."
  }
];
---

<BaseLayout
  title="Experience | UE Programmer Portfolio"
  description="Roles, ownership, and product impact."
>
  <section class="hero">
    <h1 data-i18n="experience.title">Experience</h1>
    <p data-i18n="experience.subtitle">Roles, responsibilities, and product impact.</p>
  </section>

  <section class="cards">
    {experience.map((item) => (
      <article class="card">
        <p>
          <strong data-i18n={`experience.item.${item.key}.period`}>{item.period}</strong>
        </p>
        <h2 data-i18n={`experience.item.${item.key}.role`}>{item.role}</h2>
        <p class="experience-detail" data-i18n={`experience.item.${item.key}.details`}>{item.details}</p>
      </article>
    ))}
  </section>
</BaseLayout>
