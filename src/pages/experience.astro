---
import BaseLayout from "../layouts/BaseLayout.astro";

const experience = [
  {
    period: "Апрель 2023 - настоящее время",
    role: "PORTAL TECH - Lead UE C++ программист",
    details:
      "Веду разработку мультиплеерного VR-шутера для LBE Arena на UE4/UE5. Проектирую и поддерживаю сетевую архитектуру (C++/Blueprints), включая интеграцию Advanced Sessions и собственных решений. Интегрировал и стабилизировал VR-оборудование (Oculus, Pico), улучшал производительность по FPS/latency/load. Руководил реализацией игровых фич: от ТЗ и прототипа до внутреннего тестирования и релизной сборки. Разрабатывал визуальные и UI-системы (Niagara, UMG, анимации, материалы) совместно с арт/дизайн-командой. Контролировал процесс сборок и релизов под Oculus, Pico, Windows и выделенные серверы."
  },
  {
    period: "Апрель 2022 - Май 2023",
    role: "OpenVus - Unreal Engine Developer",
    details:
      "Создавал интерактивные архитектурные VR-проекты на UE4/UE5. Реализовывал игровую логику, интерактив, освещение и анимационные сценарии (Blueprints/C++). Оптимизировал 3D-ассеты и сцены для стабильной работы в VR. Готовил и проводил VR-презентации, включая настройку оборудования и техническое сопровождение."
  },
  {
    period: "Июнь 2021 - Апрель 2022",
    role: "Prostranstvo VR - UE Tech Artist / Unreal Developer",
    details:
      "Создавал интерактивные архитектурные VR-проекты на UE4/UE5. Реализовывал игровую логику, интерактив, освещение и анимационные сценарии (Blueprints/C++). Оптимизировал 3D-ассеты и сцены для стабильной работы в VR. Готовил и проводил VR-презентации, включая настройку оборудования и техническое сопровождение."
  },
  {
    period: "Январь 2018 - Март 2021",
    role: "Фриланс - Frontend / Backend Web Developer",
    details:
      "Разрабатывал сайты и лендинги на конструкторах (Tilda/WordPress и другие CMS) под задачи малого бизнеса. Кастомизировал frontend: HTML/CSS/JavaScript, адаптивная верстка, UX-правки и ускорение загрузки. Выполнял backend-задачи: формы, обработка данных, API-интеграции, базовая серверная логика на Python/PHP. Настраивал домены, хостинг, деплой и базовое SEO."
  }
];
---

<BaseLayout
  title="Опыт работы | UE Programmer Portfolio"
  description="Роли, ответственность и продуктовый вклад Антона Бордуноса."
>
  <section class="hero">
    <h1 data-i18n="experience.title">Опыт работы</h1>
    <p data-i18n="experience.subtitle">Роли, ответственность и вклад в продукт на ключевых этапах карьеры.</p>
  </section>

  <section class="cards">
    {experience.map((item) => (
      <article class="card">
        <p>
          <strong>{item.period}</strong>
        </p>
        <h2>{item.role}</h2>
        <p>{item.details}</p>
      </article>
    ))}
  </section>
</BaseLayout>
