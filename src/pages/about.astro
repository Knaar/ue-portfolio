---
import { getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const profile = await getEntry("profile", "profile");
const { Content } = await render(profile);
const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Обо мне | UE Programmer Portfolio"
  description="Опыт, подход к разработке и контакты UE программиста."
>
  <section class="hero">
    <h1>Обо мне</h1>
    <p>
      Senior/Lead UE C++ разработчик с фокусом на VR и multiplayer. Беру задачи на
      стыке gameplay, network, backend-интеграций и production-качества.
    </p>
  </section>

  <section class="grid-2">
    <article class="card">
      <h2>Что важно в работе</h2>
      <ul>
        <li>Стабильный технический фундамент до масштабирования контента.</li>
        <li>Прозрачная коммуникация с артом, техартом, QA и дизайном.</li>
        <li>Проверяемый результат для продукта, а не только «красивый код».</li>
        <li>Ownership фичи до релиза и в post-release поддержке.</li>
      </ul>
    </article>

    <article class="card">
      <h2>Контакты</h2>
      <ul>
        <li>
          Email: <a href={`mailto:${profile.data.email}`}>{profile.data.email}</a>
        </li>
        {profile.data.telegram && (
          <li>
            Telegram: <a href={profile.data.telegram}>{profile.data.telegram}</a>
          </li>
        )}
        {profile.data.github && (
          <li>
            GitHub: <a href={profile.data.github}>{profile.data.github}</a>
          </li>
        )}
        <li>
          Опыт: <a href={`${baseUrl}experience/`}>подробный таймлайн</a>
        </li>
      </ul>
    </article>
  </section>

  <section class="card">
    <h2>Профессиональный подход</h2>
    <Content />
  </section>
</BaseLayout>
