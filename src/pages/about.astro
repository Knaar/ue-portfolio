---
import { getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const profile = await getEntry("profile", "profile");
const { Content } = await render(profile);

const experience = [
  {
    period: "2023 - н.в.",
    role: "Lead UE C++ Developer, PORTAL TECH",
    details:
      "Лид и фичмейкер в VR-продукте: единая core-платформа, релизы 7 игровых продуктов, координация разработки с 3 до 20+ человек в штате."
  },
  {
    period: "2022 - 2023",
    role: "Unreal Engine Developer, OpenVus",
    details:
      "Сетевое 3D-приложение для дистанционного обучения на UE4/UE5: голосовой чат, интерактивная среда, готовый рабочий билд."
  },
  {
    period: "2021 - 2022",
    role: "UE Tech Artist / Developer, Prostranstvo",
    details:
      "VR-туры и презентационные сцены для заказчиков: интерактив, оптимизация и техническое сопровождение показов."
  },
  {
    period: "2018 - 2021",
    role: "Frontend / Backend Developer (Freelance)",
    details:
      "Сайты на конструкторах и CMS, frontend-кастомизация, backend-задачи и автоматизация на Python."
  }
];
---

<BaseLayout
  title="Обо мне | UE Programmer Portfolio"
  description="Опыт, подход к разработке и контакты UE программиста."
>
  <section class="hero">
    <span class="badge">About</span>
    <h1>Обо мне</h1>
    <p>
      Работаю на стыке gameplay, network и технических инструментов, чтобы ускорять
      команду и выпускать стабильные VR/multiplayer фичи.
    </p>
  </section>

  <section class="grid-2">
    <article class="card">
      <h2>Опыт</h2>
      <div class="cards">
        {experience.map((item) => (
          <article>
            <p>
              <strong>{item.period}</strong>
            </p>
            <p>{item.role}</p>
            <p>{item.details}</p>
          </article>
        ))}
      </div>
    </article>

    <article class="card">
      <h2>Контакты</h2>
      <ul>
        <li>
          Email: <a href={`mailto:${profile.data.email}`}>{profile.data.email}</a>
        </li>
        {profile.data.telegram && (
          <li>
            Telegram: <a href={profile.data.telegram}>{profile.data.telegram}</a>
          </li>
        )}
        {profile.data.github && (
          <li>
            GitHub: <a href={profile.data.github}>{profile.data.github}</a>
          </li>
        )}
        {profile.data.linkedin && (
          <li>
            LinkedIn: <a href={profile.data.linkedin}>{profile.data.linkedin}</a>
          </li>
        )}
      </ul>
    </article>
  </section>

  <section class="card">
    <h2>Подход</h2>
    <Content />
  </section>
</BaseLayout>
