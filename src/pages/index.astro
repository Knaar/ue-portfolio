---
import { getCollection, getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const profile = await getEntry("profile", "profile");
const { Content } = await render(profile);
const projects = (await getCollection("projects"))
  .sort((a, b) => b.data.period.localeCompare(a.data.period))
  .slice(0, 3);
const baseUrl = import.meta.env.BASE_URL;
const experience = [
  {
    period: "2024 - настоящее время",
    role: "Senior / Lead Unreal Engine C++ Developer (VR / Multiplayer)",
    details:
      "Бизнес-критичные gameplay и сетевые подсистемы: стрельба, гранаты, урон, UI/HUD, spectator UI и серверная логика."
  },
  {
    period: "2023 - 2024",
    role: "UE Developer / Feature Owner",
    details:
      "Core-механики, сетевые взаимодействия, оптимизация производительности и backend-интеграции (JSON/REST)."
  },
  {
    period: "2020 - 2023",
    role: "Frontend / Backend Freelancer",
    details:
      "Frontend-разработка сайтов, backend-задачи и Python-автоматизация для прикладных сценариев."
  }
];

const contacts = [
  { label: "Email", url: `mailto:${profile.data.email}` },
  { label: "Telegram", url: profile.data.telegram },
  { label: "GitHub", url: profile.data.github },
  { label: "LinkedIn", url: profile.data.linkedin },
  { label: "ArtStation", url: profile.data.artstation }
].filter((item) => item.url);
---

<BaseLayout
  title={`${profile.data.name} | UE Programmer Portfolio`}
  description="Портфолио UE программиста: проекты, подход к разработке и контакты."
>
  <section class="hero hero-grid" id="home">
    <div>
      <h1>{profile.data.name}</h1>
      <p>{profile.data.title}</p>
      <div>
        <a href="#experience" data-i18n="home.cta.experience">Смотреть опыт</a>
        <span> · </span>
        <a href="#about" data-i18n="home.cta.about">Подробнее обо мне</a>
      </div>
    </div>
    <div class="avatar-wrap">
      <img
        class="avatar"
        src={`${baseUrl}images/profile.png`}
        alt="Фото: Антон Бордунос"
        loading="lazy"
      />
    </div>
  </section>

  <section class="grid-2">
    <article class="card">
      <h2 data-i18n="home.focus.title">Фокус</h2>
      <ul class="tag-list">
        {profile.data.focus.map((item) => (
          <li class="tag">{item}</li>
        ))}
      </ul>
    </article>
    <article class="card">
      <h2 data-i18n="home.skills.title">Ключевые навыки</h2>
      <ul class="tag-list">
        {profile.data.skills.map((skill) => (
          <li class="tag">{skill}</li>
        ))}
      </ul>
    </article>
  </section>

  <section id="experience">
    <h2 data-i18n="home.experience.title">Опыт работы</h2>
    <div class="cards">
      {experience.map((item) => (
        <article class="card">
          <p>
            <strong>{item.period}</strong>
          </p>
          <h3>{item.role}</h3>
          <p>{item.details}</p>
        </article>
      ))}
    </div>
    <p>
      <a href={`${baseUrl}experience/`} data-i18n="home.experience.more">Открыть полный таймлайн</a>
    </p>
  </section>

  <section id="projects">
    <h2 data-i18n="home.projects.title">Проекты</h2>
    <div class="cards">
      {projects.map((project) => (
        <article class="card">
          <h3>{project.data.title}</h3>
          <p>{project.data.summary}</p>
          <p>
            <strong>Роль:</strong> {project.data.role} · <strong>Период:</strong>{" "}
            {project.data.period}
          </p>
        </article>
      ))}
    </div>
    <p>
      <a href={`${baseUrl}projects/`} data-i18n="home.projects.more">Открыть все проекты</a>
    </p>
  </section>

  <section class="grid-2" id="about">
    <article class="card">
      <h2 data-i18n="home.about.title">Обо мне</h2>
      <Content />
      <p>
        <a href={`${baseUrl}about/`} data-i18n="home.about.more">Открыть расширенную версию</a>
      </p>
    </article>
    <article class="card">
      <h2 data-i18n="home.contacts.title">Контакты</h2>
      <ul>
        {contacts.map((contact) => (
          <li>
            <a href={contact.url}>{contact.label}</a>
          </li>
        ))}
      </ul>
    </article>
  </section>
</BaseLayout>
