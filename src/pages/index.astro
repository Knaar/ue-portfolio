---
import { getCollection, getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const profile = await getEntry("profile", "profile");
const { Content } = await render(profile);
const projects = (await getCollection("projects"))
  .sort((a, b) => b.data.period.localeCompare(a.data.period))
  .slice(0, 3);
const baseUrl = import.meta.env.BASE_URL;
const experience = [
  {
    key: 1,
    period: "Apr 2023 - Present",
    role: "PORTAL TECH - Lead UE C++ Programmer",
    details:
      "Lead multiplayer VR shooter development for LBE Arena on UE4/UE5, including networking and release flow."
  },
  {
    key: 2,
    period: "Apr 2022 - May 2023",
    role: "OpenVus - Unreal Engine Developer",
    details:
      "Built interactive architectural VR projects on UE4/UE5 with gameplay, optimization, and technical demos."
  },
  {
    key: 3,
    period: "Jun 2021 - Apr 2022",
    role: "Prostranstvo VR - UE Tech Artist / Unreal Developer",
    details:
      "Delivered VR scenes and interactions with performance tuning and on-site presentation support."
  },
  {
    key: 4,
    period: "Jan 2018 - Mar 2021",
    role: "Freelance - Frontend / Backend Web Developer",
    details:
      "Delivered websites, frontend customization, backend integrations, and Python/PHP automation."
  }
];

const contacts = [
  { label: "Email", url: `mailto:${profile.data.email}` },
  { label: "Telegram", url: profile.data.telegram },
  { label: "GitHub", url: profile.data.github },
  { label: "LinkedIn", url: profile.data.linkedin },
  { label: "ArtStation", url: profile.data.artstation }
].filter((item) => item.url);
---

<BaseLayout
  title={`${profile.data.name} | UE Programmer Portfolio`}
  description="Портфолио UE программиста: проекты, подход к разработке и контакты."
>
  <section class="hero hero-grid" id="home">
    <div>
      <h1>{profile.data.name}</h1>
      <p>{profile.data.title}</p>
      <div>
        <a href="#experience" data-i18n="home.cta.experience">View experience</a>
        <span> · </span>
        <a href="#about" data-i18n="home.cta.about">About me</a>
      </div>
    </div>
    <div class="avatar-wrap">
      <img
        class="avatar"
        src={`${baseUrl}images/profile.png`}
        alt="Фото: Антон Бордунос"
        loading="lazy"
      />
    </div>
  </section>

  <section class="grid-2">
    <article class="card">
      <h2 data-i18n="home.focus.title">Focus</h2>
      <ul class="tag-list">
        {profile.data.focus.map((item) => (
          <li class="tag">{item}</li>
        ))}
      </ul>
    </article>
    <article class="card">
      <h2 data-i18n="home.skills.title">Core skills</h2>
      <ul class="tag-list">
        {profile.data.skills.map((skill) => (
          <li class="tag">{skill}</li>
        ))}
      </ul>
    </article>
  </section>

  <section id="experience">
    <h2 data-i18n="home.experience.title">Work experience</h2>
    <div class="cards">
      {experience.map((item) => (
        <article class="card">
          <p>
            <strong data-i18n={`home.exp.${item.key}.period`}>{item.period}</strong>
          </p>
          <h3 data-i18n={`home.exp.${item.key}.role`}>{item.role}</h3>
          <p data-i18n={`home.exp.${item.key}.details`}>{item.details}</p>
        </article>
      ))}
    </div>
    <p>
      <a href={`${baseUrl}experience/`} data-i18n="home.experience.more">Open full timeline</a>
    </p>
  </section>

  <section id="projects">
    <h2 data-i18n="home.projects.title">Portfolio</h2>
    <div class="cards">
      {projects.map((project) => (
        <article class="card">
          <h3>{project.data.title}</h3>
          <p>{project.data.summary}</p>
          <p>
            <strong data-i18n="home.projects.label.role">Role:</strong> {project.data.role} ·{" "}
            <strong data-i18n="home.projects.label.period">Period:</strong>{" "}
            {project.data.period}
          </p>
        </article>
      ))}
    </div>
    <p>
      <a href={`${baseUrl}projects/`} data-i18n="home.projects.more">Open full portfolio</a>
    </p>
  </section>

  <section class="grid-2" id="about">
    <article class="card">
      <h2 data-i18n="home.about.title">About</h2>
      <Content />
      <p>
        <a href={`${baseUrl}about/`} data-i18n="home.about.more">Open full version</a>
      </p>
    </article>
    <article class="card">
      <h2 data-i18n="home.contacts.title">Contacts</h2>
      <ul>
        {contacts.map((contact) => (
          <li>
            <a href={contact.url}>{contact.label}</a>
          </li>
        ))}
      </ul>
    </article>
  </section>
</BaseLayout>
