---
import { getCollection, getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const profile = await getEntry("profile", "profile");
const projects = (await getCollection("projects"))
  .sort((a, b) => b.data.period.localeCompare(a.data.period))
  .slice(0, 3);
const { Content } = await render(profile);
const baseUrl = import.meta.env.BASE_URL;

const contacts = [
  { label: "Email", url: `mailto:${profile.data.email}` },
  { label: "Telegram", url: profile.data.telegram },
  { label: "GitHub", url: profile.data.github },
  { label: "LinkedIn", url: profile.data.linkedin },
  { label: "ArtStation", url: profile.data.artstation }
].filter((item) => item.url);
---

<BaseLayout
  title={`${profile.data.name} | UE Programmer Portfolio`}
  description="Портфолио UE программиста: проекты, подход к разработке и контакты."
>
  <section class="hero hero-grid">
    <div>
      <h1>{profile.data.name}</h1>
      <p>{profile.data.title}</p>
      <div>
        <a href={`${baseUrl}experience/`} data-i18n="home.cta.experience">Смотреть опыт</a>
        <span> · </span>
        <a href={`${baseUrl}about/`} data-i18n="home.cta.about">Подробнее обо мне</a>
      </div>
    </div>
    <div class="avatar-wrap">
      <img
        class="avatar"
        src={`${baseUrl}images/profile.png`}
        alt="Фото: Антон Бордунос"
        loading="lazy"
      />
    </div>
  </section>

  <section class="card">
    <h2 data-i18n="home.results.title">Коротко о результатах</h2>
    <ul>
      <li data-i18n="home.results.1">
        Выпустил 7 игровых продуктов на едином VR-core (один каркас, разные режимы и
        игровые оболочки).
      </li>
      <li data-i18n="home.results.2">
        Участвовал в масштабировании разработки с 3 до 20+ человек в штате.
      </li>
      <li data-i18n="home.results.3">
        Отвечаю за бизнес-критичные фичи: стрельба, гранаты, урон, взаимодействия,
        серверная логика, UI/HUD и spectator UI.
      </li>
      <li data-i18n="home.results.4">
        В стандартных VR-сессиях 10+ игроков держим целевые 72 FPS на Pico; тяжелые
        FX/UI-сцены системно дооптимизируем с техартом.
      </li>
    </ul>
  </section>

  <section class="card">
    <h2 data-i18n="home.stack.title">Tech Stack in Production</h2>
    <div class="stack-grid">
      <article class="stack-block">
        <h3 data-i18n="home.stack.engine">Engine & Code</h3>
        <ul class="tag-list">
          <li class="tag">UE4/UE5</li>
          <li class="tag">C++</li>
          <li class="tag">Blueprints</li>
          <li class="tag">Subsystems</li>
          <li class="tag">Plugin Integration</li>
        </ul>
      </article>
      <article class="stack-block">
        <h3 data-i18n="home.stack.network">Network & Multiplayer</h3>
        <ul class="tag-list">
          <li class="tag">Replication</li>
          <li class="tag">Dedicated Server</li>
          <li class="tag">Backend Integration</li>
          <li class="tag">JSON/Proto Flows</li>
          <li class="tag">Advanced Sessions</li>
          <li class="tag">Spectator UI</li>
          <li class="tag">Scenario/Wave Systems</li>
        </ul>
      </article>
      <article class="stack-block">
        <h3 data-i18n="home.stack.vr">VR & Performance</h3>
        <ul class="tag-list">
          <li class="tag">Oculus / Pico</li>
          <li class="tag">72 FPS Target</li>
          <li class="tag">Unreal Insights</li>
          <li class="tag">CPU/GPU Profiling</li>
          <li class="tag">Pooling Systems</li>
        </ul>
      </article>
      <article class="stack-block">
        <h3 data-i18n="home.stack.gameplay">Gameplay & UX</h3>
        <ul class="tag-list">
          <li class="tag">Weapons Systems</li>
          <li class="tag">Damage & Interaction</li>
          <li class="tag">Geometry Collection</li>
          <li class="tag">Niagara</li>
          <li class="tag">UMG / Admin UI</li>
        </ul>
      </article>
      <article class="stack-block">
        <h3 data-i18n="home.stack.process">Process & Delivery</h3>
        <ul class="tag-list">
          <li class="tag">Git / GitHub</li>
          <li class="tag">Release Management</li>
          <li class="tag">Cross-team Coordination</li>
          <li class="tag">Knowledge Base</li>
          <li class="tag">Feature Ownership</li>
        </ul>
      </article>
    </div>
  </section>

  <section>
    <h2 data-i18n="home.experience.title">Опыт работы (snapshot)</h2>
    <div class="cards">
      {projects.map((project) => (
        <article class="card">
          <h3>{project.data.title}</h3>
          <p>{project.data.summary}</p>
          <p>
            <strong>Роль:</strong> {project.data.role} · <strong>Период:</strong>{" "}
            {project.data.period}
          </p>
        </article>
      ))}
    </div>
    <p>
      <a href={`${baseUrl}experience/`} data-i18n="home.experience.more">Открыть полный опыт</a>
    </p>
  </section>

  <section class="card">
    <h2 data-i18n="home.contacts.title">Контакты</h2>
    <ul>
      {contacts.map((contact) => (
        <li>
          <a href={contact.url}>{contact.label}</a>
        </li>
      ))}
    </ul>
  </section>

  <section class="card">
    <h2 data-i18n="home.approach.title">Профессиональный подход</h2>
    <Content />
  </section>
</BaseLayout>
