---
import { getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const profile = await getEntry("profile", "profile");
const { Content } = await render(profile);
const baseUrl = import.meta.env.BASE_URL;
const experience = [
  {
    key: 1,
    period: "Apr 2023 - Present",
    role: "PORTAL TECH - Lead UE C++ Programmer",
    details:
      "Led multiplayer VR shooter development for LBE Arena on UE4/UE5. Designed and maintained network architecture (C++/Blueprints), integrated Advanced Sessions and custom solutions, stabilized Oculus/Pico pipelines, improved FPS/latency/load, and drove features from design docs to release builds."
  },
  {
    key: 2,
    period: "Apr 2022 - May 2023",
    role: "OpenVus - Unreal Engine Developer",
    details:
      "Built interactive architectural VR projects on UE4/UE5, implemented gameplay/interaction/lighting scenarios (Blueprints/C++), optimized scenes for stable VR runtime, and handled technical support for demos."
  },
  {
    key: 3,
    period: "Jun 2021 - Apr 2022",
    role: "Prostranstvo VR - UE Tech Artist / Unreal Developer",
    details:
      "Delivered interactive VR architectural content, built logic and visual scenarios, optimized assets and levels, and supported equipment setup."
  },
  {
    key: 4,
    period: "Jan 2018 - Mar 2021",
    role: "Freelance - Frontend / Backend Web Developer",
    details:
      "Developed websites/landing pages, customized frontend, handled backend/API tasks, and maintained deployment and SEO basics."
  }
];

const contacts = [
  { label: "Email", url: `mailto:${profile.data.email}` },
  { label: "Telegram", url: profile.data.telegram },
  { label: "GitHub", url: profile.data.github },
  { label: "LinkedIn", url: profile.data.linkedin },
  { label: "ArtStation", url: profile.data.artstation }
].filter((item) => item.url);
const portfolioItems = [
  {
    title: "Sparrow Yard Shooter",
    image: `${baseUrl}images/portfolio/sparrow-shooter.svg`,
    description:
      "Arena prototype where players defend a Moscow courtyard from hyperactive cyber-sparrows. Focus: responsive shooting loop and readable hit feedback.",
    youtube: "https://youtube.com/",
    build: "https://example.com/build-sparrow-shooter",
    guide: "https://example.com/guide-sparrow-shooter"
  },
  {
    title: "Metro Tunnel Rush VR",
    image: `${baseUrl}images/portfolio/metro-rush.svg`,
    description:
      "Co-op VR sprint scenario inside a shifting metro tunnel with dynamic hazards. Focus: comfort-first locomotion and synchronized event timing.",
    youtube: "https://youtube.com/",
    build: "https://example.com/build-metro-rush",
    guide: "https://example.com/guide-metro-rush"
  },
  {
    title: "Factory Siege Protocol",
    image: `${baseUrl}images/portfolio/factory-siege.svg`,
    description:
      "Wave-defense mode set in a modular factory map. Focus: network-stable AI waves, weapon readability, and fast iteration through data-driven tuning.",
    youtube: "https://youtube.com/",
    build: "https://example.com/build-factory-siege",
    guide: "https://example.com/guide-factory-siege"
  },
  {
    title: "Galactic Cart Delivery",
    image: `${baseUrl}images/portfolio/galactic-cart.svg`,
    description:
      "Arcade multiplayer mode where squads escort cargo carts in low-gravity sectors. Focus: teamwork mechanics and spectator-friendly pacing.",
    youtube: "https://youtube.com/",
    build: "https://example.com/build-galactic-cart",
    guide: "https://example.com/guide-galactic-cart"
  }
];
---

<BaseLayout
  title={`${profile.data.name} | UE Programmer Portfolio`}
  description="Портфолио UE программиста: проекты, подход к разработке и контакты."
>
  <section class="hero hero-grid" id="home">
    <div>
      <h1>{profile.data.name}</h1>
      <p>{profile.data.title}</p>
      <div>
        <a href="#experience" data-i18n="home.cta.experience">View experience</a>
        <span> · </span>
        <a href="#about" data-i18n="home.cta.about">About me</a>
      </div>
    </div>
    <div class="avatar-wrap">
      <img
        class="avatar"
        src={`${baseUrl}images/profile.png`}
        alt="Фото: Антон Бордунос"
        loading="lazy"
      />
    </div>
  </section>

  <section class="grid-2">
    <article class="card">
      <h2 data-i18n="home.focus.title">Focus</h2>
      <ul class="tag-list">
        {profile.data.focus.map((item) => (
          <li class="tag">{item}</li>
        ))}
      </ul>
    </article>
    <article class="card">
      <h2 data-i18n="home.skills.title">Core skills</h2>
      <ul class="tag-list">
        {profile.data.skills.map((skill) => (
          <li class="tag">{skill}</li>
        ))}
      </ul>
    </article>
  </section>

  <section id="experience">
    <h2 data-i18n="home.experience.title">Work experience</h2>
    <div class="cards">
      {experience.map((item) => (
        <article class="card">
          <p>
            <strong data-i18n={`experience.item.${item.key}.period`}>{item.period}</strong>
          </p>
          <h3 data-i18n={`experience.item.${item.key}.role`}>{item.role}</h3>
          <p data-i18n={`experience.item.${item.key}.details`}>{item.details}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="projects">
    <h2 data-i18n="home.projects.title">Portfolio</h2>
    <div class="portfolio-grid">
      {portfolioItems.map((item) => (
        <details class="portfolio-card">
          <summary class="portfolio-summary" aria-label={`Open ${item.title}`}>
            <img class="portfolio-thumb" src={item.image} alt={`Preview: ${item.title}`} loading="lazy" />
            <span class="portfolio-title">{item.title}</span>
          </summary>
          <div class="portfolio-body">
            <p>{item.description}</p>
            <ul class="portfolio-links">
              <li>
                <a href={item.youtube} target="_blank" rel="noreferrer" data-i18n="projects.link.youtube">
                  YouTube video
                </a>
              </li>
              <li>
                <a href={item.build} target="_blank" rel="noreferrer" data-i18n="projects.link.build">
                  Build link
                </a>
              </li>
              <li>
                <a href={item.guide} target="_blank" rel="noreferrer" data-i18n="projects.link.guide">
                  Guide link
                </a>
              </li>
            </ul>
          </div>
        </details>
      ))}
    </div>
  </section>

  <section id="about" class="card">
    <h2 data-i18n="home.about.title">About</h2>
    <Content />
  </section>

  <section id="contacts" class="card">
    <h2 data-i18n="home.contacts.title">Contacts</h2>
    <ul>
      {contacts.map((contact) => (
        <li>
          <a href={contact.url}>{contact.label}</a>
        </li>
      ))}
    </ul>
  </section>

  <script>
    const portfolioCards = Array.from(document.querySelectorAll(".portfolio-card"));
    portfolioCards.forEach((card) => {
      card.addEventListener("toggle", () => {
        if (!card.open) return;
        portfolioCards.forEach((otherCard) => {
          if (otherCard !== card) {
            otherCard.open = false;
          }
        });
      });
    });
  </script>
</BaseLayout>
