        es: {
          "nav.home": "Inicio",
          "nav.experience": "Experiencia",
          "nav.projects": "Proyectos",
          "nav.about": "Sobre mi",
          "home.cta.experience": "Ver experiencia",
          "home.cta.about": "Sobre mi",
          "home.experience.title": "Experiencia laboral",
          "home.experience.more": "Abrir linea de tiempo completa",
          "home.projects.title": "Proyectos",
