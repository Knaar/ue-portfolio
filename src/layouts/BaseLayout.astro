---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={canonicalUrl.toString()} />
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={`${baseUrl}#home`}>UE Portfolio</a>
      <nav>
        <a href={`${baseUrl}#home`} data-i18n="nav.home">Главная</a>
        <a href={`${baseUrl}#experience`} data-i18n="nav.experience">Опыт</a>
        <a href={`${baseUrl}#projects`} data-i18n="nav.projects">Проекты</a>
        <a href={`${baseUrl}#about`} data-i18n="nav.about">Обо мне</a>
      </nav>
      <div class="lang-switch">
        <select id="lang-select" class="lang-select" aria-label="Language selector">
          <option value="ru">RU</option>
          <option value="en">EN</option>
          <option value="es">ES</option>
        </select>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <p data-i18n="footer.copy">© {new Date().getFullYear()} UE Programmer Portfolio</p>
    </footer>
    <script>
      const dict = {
