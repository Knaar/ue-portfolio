          "about.values.4": "Ownership claro: si una feature es mia, la llevo a produccion y soporte.",
          "about.contacts.title": "Contactos",
          "about.exp.link": "Experiencia: linea de tiempo completa",
          "about.help.title": "Como ayudo al equipo",
          "about.help.1": "Liderazgo y ownership de features en producto en vivo.",
          "about.help.2": "Sistemas de red y VR: de arquitectura a rendimiento y UX.",
          "about.help.3": "Mentalidad backend/frontend para integraciones mas solidas.",
          "about.help.4": "Experiencia practica en calidad de releases y delivery.",
          "projects.title": "Proyectos",
          "projects.subtitle": "Esta seccion se esta completando. Pronto habra casos detallados.",
          "projects.ready.title": "Que puedes ver ahora",
          "projects.ready.1": "Experiencia - roles clave y contribucion.",
          "projects.ready.2": "Inicio - resultados, stack y sistemas base.",
          "projects.ready.3": "Materiales y demos adicionales disponibles bajo solicitud.",
          "experience.title": "Experiencia laboral",
          "experience.subtitle": "Roles, responsabilidad e impacto de producto en etapas clave.",
          "footer.copy": `© ${new Date().getFullYear()} UE Programmer Portfolio`
        }
      };

      const savedLang = localStorage.getItem("site-lang") || "en";
      const applyLang = (lang) => {
        const table = dict[lang] ?? dict.en;
        document.documentElement.lang = lang;
        document.querySelectorAll("[data-i18n]").forEach((el) => {
          const key = el.getAttribute("data-i18n");
          if (key && table[key]) {
            el.textContent = table[key];
          }
        });
        const select = document.getElementById("lang-select");
        if (select instanceof HTMLSelectElement) {
          select.value = lang;
        }
        localStorage.setItem("site-lang", lang);
      };

      const select = document.getElementById("lang-select");
      if (select instanceof HTMLSelectElement) {
        select.addEventListener("change", () => {
          const lang = select.value || "en";
          applyLang(lang);
        });
      }

      applyLang(savedLang);
    </script>
  </body>
</html>
